# ============================================
# Сервер (ОБЯЗАТЕЛЬНО: измените на свои значения!)
# ============================================
SERVER_HOST=your_server_ip_here
DOMAIN=your-domain.duckdns.org

# ============================================
# MinIO (обязательно смените пароль!)
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MINIO_BUCKET=audio-bucket-prod

# ============================================
# Kafka
# ============================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ============================================
# Telegram Bot (обязательно!)
# ============================================
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ============================================
# AssemblyAI (обязательно!)
# ============================================
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# ============================================
# Web App URL (GitHub Pages)
# ============================================
WEATHER_WEBAPP_URL=https://your-username.github.io/weather-report


# ============================================
# Database (для будущих сервисов)
# ============================================
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# ============================================
# Мониторинг (опционально)
# ============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ============================================
# JWT
# ============================================
JWT_PRIVATE_KEY=...
JWT_PUBLIC_KEY=...
